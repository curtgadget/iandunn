---
// PageHeader — the standard page-opening block: eyebrow, title, and an
// optional intro paragraph. Used by every page except Home.
interface Props {
  eyebrow: string;
  title: string;
  intro?: string;
}
const { eyebrow, title, intro } = Astro.props;
---

<section class="section page-head">
  <p class="eyebrow">{eyebrow}</p>
  <h1 class="page-title">{title}</h1>
  {intro && <p class="page-intro">{intro}</p>}
</section>

<style>
  .page-head {
    padding-block: clamp(2.5rem, 6vw, 4.5rem) clamp(1.75rem, 4vw, 2.75rem);
  }
  .page-title {
    margin-top: 12px;
    font: 400 clamp(2.6rem, 7vw, 4.5rem) / 1.04 var(--font-head);
  }
  .page-intro {
    margin-top: 20px;
    max-width: 560px;
    font: 400 18px/1.6 var(--font-body);
    color: var(--ink-soft);
  }
</style>
