---
// ContribGrid — GitHub contribution heatmap, rendered from real build-time
// data (see src/lib/contrib.js). Monospace lives here and only here, where
// it reads as data. All three stats are computed from the real calendar.
interface Props {
  data: {
    cells: number[][];
    months: { label: string; week: number }[];
    total: number;
    activeDays: number;
    streak: number;
  };
}
const { cells, months, total, activeDays, streak } = Astro.props.data;

const fmt = (n: number) => n.toLocaleString('en-US');
const dayLabels = ['', 'Mon', '', 'Wed', '', 'Fri', ''];
---

<div class="contrib">
  <div class="contrib-head">
    <p class="contrib-where">
      Last 12 months ·
      <a href="https://github.com/curtgadget" target="_blank" rel="noopener noreferrer">
        github.com/curtgadget
      </a>
    </p>
    <div class="stats">
      <div class="stat">
        <span class="stat-num">{fmt(total)}</span>
        <span class="stat-label">contributions</span>
      </div>
      <div class="stat">
        <span class="stat-num">{fmt(activeDays)}</span>
        <span class="stat-label">active days</span>
      </div>
      <div class="stat">
        <span class="stat-num">{fmt(streak)}</span>
        <span class="stat-label">day streak</span>
      </div>
    </div>
  </div>

  <div class="contrib-scroll">
    <div class="contrib-body" style={`--weeks:${cells.length}`}>
      <div class="corner" aria-hidden="true"></div>
      <div class="months" aria-hidden="true">
        {months.map((m) => <span style={`grid-column:${m.week + 1}`}>{m.label}</span>)}
      </div>
      <div class="day-labels" aria-hidden="true">
        {dayLabels.map((d) => <span>{d}</span>)}
      </div>
      <div
        class="grid"
        role="img"
        aria-label={`${fmt(total)} GitHub contributions in the last year`}
      >
        {
          cells.map((week) => (
            <div class="week">
              {week.map((level) => <div class={`cell lvl-${level}`} />)}
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div class="legend">
    <span>Less</span>
    <span class="swatch lvl-0"></span>
    <span class="swatch lvl-1"></span>
    <span class="swatch lvl-2"></span>
    <span class="swatch lvl-3"></span>
    <span class="swatch lvl-4"></span>
    <span>More</span>
  </div>
</div>

<style>
  .contrib {
    width: 100%;
  }

  /* ── Header ─────────────────────────────────────────────── */
  .contrib-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 20px 32px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }
  .contrib-where {
    font: 400 12px/1 var(--font-mono);
    letter-spacing: 0.02em;
    color: var(--muted);
  }
  .contrib-where a {
    color: var(--muted);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
  }
  .contrib-where a:hover {
    color: var(--accent-strong);
  }

  .stats {
    display: flex;
    gap: 28px;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .stat-num {
    font: 400 26px/0.9 var(--font-head);
    color: var(--ink);
  }
  .stat-label {
    font: 400 11px/1 var(--font-mono);
    letter-spacing: 0.04em;
    color: var(--muted);
  }

  /* ── Grid ───────────────────────────────────────────────── */
  .contrib-scroll {
    overflow-x: auto;
    scrollbar-width: thin;
  }
  /* day-labels + grid share one CSS grid so the label column
     stretches to exactly the cell-grid height. --weeks is the
     real week count, set inline from the fetched data. */
  .contrib-body {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 6px 8px;
    min-width: 620px;
  }
  .corner {
    grid-area: 1 / 1;
  }
  .months {
    grid-area: 1 / 2;
    display: grid;
    grid-template-columns: repeat(var(--weeks), 1fr);
    font: 400 10px/1 var(--font-mono);
    letter-spacing: 0.04em;
    color: var(--muted);
  }
  .months span {
    white-space: nowrap;
  }
  .day-labels {
    grid-area: 2 / 1;
    display: flex;
    flex-direction: column;
  }
  .day-labels span {
    flex: 1;
    display: flex;
    align-items: center;
    font: 400 10px/1 var(--font-mono);
    color: var(--muted);
  }

  .grid {
    grid-area: 2 / 2;
    display: grid;
    grid-template-columns: repeat(var(--weeks), 1fr);
    gap: 3px;
  }
  .week {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .cell {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 1px;
  }

  /* 5-level green ramp, derived from --green via color-mix. */
  .lvl-0 {
    background: var(--contrib-empty);
  }
  .lvl-1 {
    background: color-mix(in srgb, var(--green) 28%, var(--contrib-empty));
  }
  .lvl-2 {
    background: color-mix(in srgb, var(--green) 55%, var(--contrib-empty));
  }
  .lvl-3 {
    background: color-mix(in srgb, var(--green) 78%, var(--contrib-empty));
  }
  .lvl-4 {
    background: var(--green);
  }

  /* ── Legend ─────────────────────────────────────────────── */
  .legend {
    margin-top: 16px;
    display: flex;
    gap: 7px;
    align-items: center;
    justify-content: flex-end;
    font: 400 11px/1 var(--font-mono);
    color: var(--muted);
  }
  .swatch {
    width: 10px;
    height: 10px;
    border-radius: 1px;
  }
</style>
