---
// SocialIcon — line-art glyphs for each social channel.
// SVGs use currentColor; the wrapper sets `color` so callers can tint them.
interface Props {
  id: 'linkedin' | 'github' | 'threads' | 'instagram' | 'appstore' | 'email' | 'calendar';
  size?: number;
  color?: string;
}
const { id, size = 14, color = 'currentColor' } = Astro.props;

const stroke = {
  stroke: 'currentColor',
  'stroke-width': 1.6,
  fill: 'none',
  'stroke-linecap': 'round',
  'stroke-linejoin': 'round',
} as const;
const solid = { fill: 'currentColor', stroke: 'none' } as const;
---

<span class="icon" style={`color:${color}`}>
  {
    id === 'linkedin' && (
      <svg viewBox="0 0 24 24" width={size} height={size} aria-hidden="true">
        <rect x="2.5" y="2.5" width="19" height="19" rx="2" {...stroke} />
        <line x1="7" y1="10.5" x2="7" y2="17" {...stroke} />
        <circle cx="7" cy="7.4" r="0.9" {...solid} />
        <path d="M11 17v-6.5M11 13c0-1.5 1-2.5 2.4-2.5s2.6 1 2.6 2.5V17" {...stroke} />
      </svg>
    )
  }
  {
    id === 'github' && (
      <svg viewBox="0 0 24 24" width={size} height={size} aria-hidden="true">
        <path
          d="M12 2.5a9.5 9.5 0 0 0-3 18.5c.5.1.7-.2.7-.5v-1.7c-2.7.6-3.3-1.3-3.3-1.3-.4-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.5 2.3 1.1 2.9.8.1-.6.3-1.1.6-1.3-2.2-.2-4.5-1.1-4.5-4.8 0-1.1.4-1.9 1-2.6-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1 .8-.2 1.7-.3 2.5-.3s1.7.1 2.5.3c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.5 1 2.6 0 3.7-2.3 4.6-4.5 4.8.4.3.7.9.7 1.8v2.6c0 .3.2.6.7.5A9.5 9.5 0 0 0 12 2.5Z"
          {...stroke}
        />
      </svg>
    )
  }
  {
    id === 'threads' && (
      <svg viewBox="0 0 24 24" width={size} height={size} aria-hidden="true">
        <path
          d="M16.7 11.3c-.1-.05-.2-.09-.3-.13-.2-3.3-1.96-5.2-4.94-5.22h-.04c-1.8 0-3.3.77-4.21 2.16l1.65 1.13c.69-1.04 1.77-1.27 2.56-1.27h.03c.99 0 1.74.29 2.23.86.36.42.6 1 .73 1.74-.94-.16-1.96-.21-3.05-.15-3.08.18-5.06 1.97-4.93 4.47.07 1.27.7 2.36 1.79 3.07 1.06.7 2.45 1.02 3.86.93 1.86-.1 3.31-.81 4.32-2.1.77-.98 1.26-2.26 1.47-3.86.88.53 1.53 1.22 1.88 2.05.6 1.42.64 3.76-1.27 5.67-1.66 1.66-3.67 2.39-6.71 2.41h-.01c-3.38-.03-5.93-1.11-7.6-3.21C2.07 17.62 1.27 14.97 1.25 12c.02-2.97.82-5.62 2.38-7.86C5.31 2.04 7.87.97 11.24.94c3.39.03 5.99 1.1 7.71 3.19.84 1.02 1.48 2.31 1.9 3.81l-1.9.5c-.34-1.2-.83-2.22-1.45-2.97-1.34-1.63-3.36-2.47-6.27-2.49-2.83.02-4.97.86-6.36 2.5C3.61 7.07 2.97 9.32 2.95 12c.02 2.68.66 4.93 1.92 6.51 1.39 1.64 3.53 2.48 6.36 2.5 2.55-.02 4.23-.62 5.63-2.02 1.6-1.59 1.57-3.55 1.06-4.75-.3-.7-.85-1.29-1.58-1.74-.18.93-.46 1.75-.85 2.46-.84 1.55-2.04 2.39-3.56 2.5-1.16.08-2.27-.19-3.11-.75-1-.66-1.58-1.69-1.65-2.89-.07-1.16.39-2.17 1.31-2.92.88-.71 2.12-1.13 3.58-1.21 1.08-.06 2.09 0 3.02.16-.12-.74-.37-1.32-.74-1.74-.51-.57-1.27-.86-2.27-.86h-.04c-.8 0-1.89.24-2.58 1.27z"
          {...solid}
        />
      </svg>
    )
  }
  {
    id === 'instagram' && (
      <svg viewBox="0 0 24 24" width={size} height={size} aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="4.5" {...stroke} />
        <circle cx="12" cy="12" r="4" {...stroke} />
        <circle cx="17.2" cy="6.8" r="0.9" {...solid} />
      </svg>
    )
  }
  {
    id === 'appstore' && (
      <svg viewBox="0 0 24 24" width={size} height={size} aria-hidden="true">
        <circle cx="12" cy="12" r="9.5" {...stroke} />
        <path d="M7.5 16l3.2-5.5M16.5 16l-3.2-5.5M9.5 14.5h7M9.7 10.5l2.3-4 2.3 4" {...stroke} />
      </svg>
    )
  }
  {
    id === 'email' && (
      <svg viewBox="0 0 24 24" width={size} height={size} aria-hidden="true">
        <rect x="2.5" y="5" width="19" height="14" rx="1.5" {...stroke} />
        <path d="M3 6l9 7 9-7" {...stroke} />
      </svg>
    )
  }
  {
    id === 'calendar' && (
      <svg viewBox="0 0 24 24" width={size} height={size} aria-hidden="true">
        <rect x="3" y="5" width="18" height="16" rx="2" {...stroke} />
        <line x1="3" y1="10" x2="21" y2="10" {...stroke} />
        <line x1="8" y1="2.5" x2="8" y2="7" {...stroke} />
        <line x1="16" y1="2.5" x2="16" y2="7" {...stroke} />
      </svg>
    )
  }
</span>

<style>
  .icon {
    display: inline-flex;
    line-height: 0;
  }
</style>
