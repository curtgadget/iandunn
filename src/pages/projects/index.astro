---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import PageHeader from '../../components/PageHeader.astro';
import ProjectVisual from '../../components/ProjectVisual.astro';
// Screenshot vendored from the centerref-site repo (src/assets/screens/).
import crWatch from '../../assets/screens/watch-active-1h.png';

const LIVE = '#3f6f49';
const FLIGHT = '#a9762f';
const CONCEPT = '#8a7d66';

// Every project is one row with the same skeleton: a left rail (mark,
// name, status) and a content column that leads with the tagline set
// large. A `screenshot` row also carries a real device shot; a `text`
// row leans on the tagline as its visual anchor — no hollow image box.
// A text row graduates to a screenshot row by adding `shot` + `shotAlt`
// and switching `layout`.
//
// mark.fit: 'contain' = a logo on the sand mat · 'cover' = an app icon
// shown full-bleed · 'mono' = a typeset initial, for projects with no art.
const projects = [
  {
    name: 'FutAve',
    layout: 'text',
    mark: { fit: 'contain', src: '/logos/futave-mark.svg', alt: 'FutAve logo' },
    status: 'Live',
    statusColor: LIVE,
    tagline: 'A taste engine for soccer.',
    body: 'Not another live-scores app. FutAve is a curation layer: its Wave Detector scores how exciting a match will be before kickoff, weighing form, rivalry, and what is at stake, and an AI layer writes the context for why it matters. Live scores, lineups, and event timelines follow, for the matches actually worth your time.',
    meta: 'iOS and web, Android soon · React Native, Next.js, Payload CMS',
    url: 'https://futave.com',
    cta: 'Visit futave.com',
    external: true,
  },
  {
    name: 'TheraBasics',
    layout: 'text',
    mark: { fit: 'cover', src: '/logos/therabasics-icon.png', alt: 'TheraBasics app icon' },
    status: 'TestFlight',
    statusColor: FLIGHT,
    tagline: 'The work between sessions.',
    body: 'Built with Raven, my wife and a psychologist. A mobile app gives clients the exercises and reflection that happen between appointments; a dashboard gives the therapist a place to review them. HIPAA-compliant, built on Supabase.',
    meta: 'iOS, Android & web · React Native, Next.js',
    url: 'https://therabasics.com',
    cta: 'Visit therabasics.com',
    external: true,
  },
  {
    name: 'Center Ref',
    layout: 'screenshot',
    mark: { fit: 'contain', src: '/logos/centerref-icon.svg', alt: 'Center Ref logo' },
    shot: crWatch,
    shotAlt: 'Center Ref running a match on Apple Watch',
    status: 'Public beta',
    statusColor: FLIGHT,
    tagline: 'Ref the match. Not the screen.',
    body: 'A watch-first match clock for youth-soccer referees. The clock, score, and event log live on the Apple Watch, designed to be read in a two-second glance under bright sun. AYSO and Club Soccer division presets, haptic period signals you learn by feel, and stoppage time that arms its own countdown.',
    meta: 'Apple Watch + iPhone · Swift',
    url: 'https://centerref.com',
    cta: 'Visit centerref.com',
    external: true,
  },
  {
    name: 'Numbrix',
    layout: 'text',
    mark: { fit: 'mono' },
    status: 'Concept',
    statusColor: CONCEPT,
    tagline: 'Multiplication by strategy, not drill.',
    body: 'A math game for kids built on derived facts: working out new answers from the ones you already know, instead of drilling flashcards. Still a concept, sketched for my own kids.',
    meta: 'Concept and research',
    url: 'https://numbrix.app',
    cta: 'numbrix.app',
    external: true,
  },
];
---

<BaseLayout
  title="Projects — Ian Dunn"
  description="Side projects from Ian Dunn — FutAve, TheraBasics, Center Ref, and Numbrix."
>
  <SiteNav active="Projects" />

  <main id="main">
    <PageHeader
      eyebrow="Projects"
      title="Side projects"
      intro="Four things I'm building outside of work, in different states of done. I ship slowly, on nights and weekends, around a day job and three kids."
    />

    <section class="section project-list">
      {
        projects.map((p) => (
          <article class:list={['project', p.layout === 'screenshot' ? 'has-shot' : 'text-only']}>
            <div class="project-id">
              <span class:list={['project-mark', `is-${p.mark.fit}`]}>
                {p.mark.fit === 'mono' ? (
                  <span class="mark-mono" aria-hidden="true">
                    {p.name.charAt(0)}
                  </span>
                ) : (
                  <img src={p.mark.src} alt={p.mark.alt} loading="lazy" decoding="async" />
                )}
              </span>
              <h2 class="project-name">{p.name}</h2>
              <span class="project-status">
                <span class="dot" style={`background:${p.statusColor}`} />
                {p.status}
              </span>
            </div>

            <div class="project-content">
              <p class="project-tagline">{p.tagline}</p>

              <div class="project-lower">
                {p.layout === 'screenshot' && (
                  <div class="project-visual">
                    <ProjectVisual kind="screenshot" src={p.shot} alt={p.shotAlt} />
                  </div>
                )}
                <div class="project-detail">
                  <p class="project-body">{p.body}</p>
                  <p class="project-meta">{p.meta}</p>
                  <a
                    class="project-link"
                    href={p.url}
                    target={p.external ? '_blank' : undefined}
                    rel={p.external ? 'noopener noreferrer' : undefined}
                  >
                    {p.cta} →
                  </a>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .project-list {
    padding-bottom: clamp(3.5rem, 8vw, 6rem);
  }

  /* Every row shares one skeleton: a left rail and a content column.
     The rail width is fixed so project names align down the page. */
  .project {
    display: grid;
    grid-template-columns: 0.9fr 2.6fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
    padding-block: clamp(2.5rem, 5vw, 3.5rem);
    border-top: 1px solid var(--line);
  }
  .project:last-child {
    border-bottom: 1px solid var(--line);
  }

  /* ── Left rail: mark, name, status ──────────────────────────── */
  .project-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    background: var(--paper-sand);
    border: 1px solid var(--line);
    overflow: hidden;
  }
  /* A logo is a mark — centered, capped, room around it. */
  .project-mark.is-contain img {
    max-width: 56%;
    max-height: 56%;
    object-fit: contain;
  }
  /* An app icon owns its own background — show it full-bleed. */
  .project-mark.is-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .mark-mono {
    font: 400 1.6rem/1 var(--font-head);
    color: var(--muted);
  }

  .project-name {
    margin-top: 16px;
    font: 400 clamp(1.9rem, 3.4vw, 2.6rem) / 1.05 var(--font-head);
  }
  .project-status {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-top: 10px;
    font-size: 12px;
    color: var(--muted);
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  /* ── Content column: the tagline leads, then the lower band ─── */
  .project-content {
    display: flex;
    flex-direction: column;
    gap: clamp(1.1rem, 2.6vw, 1.7rem);
  }
  /* Set large, the tagline is the row's visual anchor — it carries
     a text row on its own and decks a screenshot row. */
  .project-tagline {
    max-width: 30ch;
    font: italic 400 clamp(1.45rem, 2.6vw, 2.15rem) / 1.25 var(--font-head);
    color: var(--ink-soft);
  }

  .project-lower {
    display: grid;
    gap: clamp(1.25rem, 3vw, 2.25rem);
    align-items: start;
  }
  /* A screenshot row splits the lower band: device shot, then detail. */
  .has-shot .project-lower {
    grid-template-columns: 1fr 1.25fr;
  }
  .project-visual {
    width: 100%;
    max-width: 320px;
  }

  .project-body {
    max-width: 62ch;
    font: 400 16px/1.65 var(--font-body);
    color: var(--ink-body);
  }
  .project-meta {
    margin-top: 16px;
    font-size: 13px;
    color: var(--muted);
  }
  .project-link {
    display: inline-block;
    margin-top: 16px;
    font-size: 14px;
    font-weight: 500;
    color: var(--accent-strong);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
  }
  .project-link:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  /* The device shot stacks above its detail before the tile gets cramped. */
  @media (max-width: 880px) {
    .has-shot .project-lower {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 760px) {
    .project {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
