---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PageHeader from '../components/PageHeader.astro';

// The four categories the writing will be filed under (from the brief).
const categories = [
  {
    name: 'Building',
    desc: 'Side projects, weekend code, and the actual mechanics of shipping things with three kids in the house.',
  },
  {
    name: 'Leading',
    desc: 'Engineering management: hiring, feedback, and what changes when you stop writing code for a living.',
  },
  {
    name: 'Learning',
    desc: 'Books, talks, and papers worth underlining, including the things I got wrong on the second read.',
  },
  {
    name: 'Life',
    desc: 'Fatherhood, faith, Los Angeles, Belize, the church livestream, and the Saturday sideline.',
  },
];
---

<BaseLayout
  title="Writing — Ian Dunn"
  description="Notes from Ian Dunn on building, leading, learning, and life. Not published yet. The notebook is on its way."
>
  <SiteNav active="Writing" />

  <main id="main">
    <PageHeader
      eyebrow="Writing"
      title="The notebook"
      intro="Short pieces on building, leading, learning, and life. The categories are set; the writing is still mostly in my head."
    />

    <section class="section categories">
      <div class="category-grid">
        {
          categories.map((c) => (
            <article class="category">
              <h2 class="category-name">{c.name}</h2>
              <p class="category-desc">{c.desc}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section archive">
      <div class="empty-card">
        <p class="eyebrow">The archive</p>
        <p class="empty-line">Nothing published yet.</p>
        <p class="empty-note">
          The writing exists; the publishing hasn’t caught up. When the first
          piece is ready I’ll post it on
          <a href="https://www.threads.com/@curtgadget" target="_blank" rel="noopener noreferrer">Threads</a>.
          Or <a href="mailto:iandunn@iandunn.net">email me</a> and I’ll tell
          you directly.
        </p>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .categories {
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }
  /* hairline gap-grid — these are informational, not links */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .category {
    background: var(--paper);
    padding: 26px 22px;
  }
  .category-name {
    font: 400 24px/1 var(--font-head);
  }
  .category-desc {
    margin-top: 10px;
    font: 400 14px/1.6 var(--font-body);
    color: var(--ink-body);
  }

  .archive {
    padding-bottom: clamp(3.5rem, 8vw, 6rem);
  }
  .empty-card {
    border: 1px dashed var(--line);
    padding: clamp(2.5rem, 6vw, 4rem) clamp(1.5rem, 4vw, 3rem);
    text-align: center;
  }
  .empty-line {
    margin-top: 10px;
    font: 400 clamp(1.6rem, 3vw, 2.2rem) / 1.15 var(--font-head);
  }
  .empty-note {
    margin: 14px auto 0;
    max-width: 460px;
    font: 400 15px/1.65 var(--font-body);
    color: var(--ink-body);
  }
  .empty-note a {
    color: var(--accent-strong);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
  }
</style>
